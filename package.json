{
  "name": "@ekaone/killx",
  "version": "0.1.0",
  "description": "A cross-platform process tree killer",
  "keywords": [
    "kill",
    "process",
    "tree",
    "cross-platform",
    "cli",
    "zero-dependency"
  ],
  "author": {
    "name": "Eka Prasetia",
    "email": "ekaone3033@gmail.com",
    "url": "https://prasetia.me"
  },
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm typecheck && pnpm clean && pnpm tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run clean && pnpm run typecheck && pnpm run test && pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "bin": {
    "killx": "./dist/cli.cjs"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ekaone/killx.git"
  },
  "bugs": {
    "url": "https://github.com/ekaone/killx/issues"
  },
  "homepage": "https://github.com/ekaone/killx#readme"
}
